# SSH Brute Force Detector — Backend environment
MODE=simulation
SIMULATED_LOG_PATH=./data/simulated_auth.log
LIVE_LOG_PATH=/var/log/auth.log
DATABASE_URL=sqlite:///./data/detector.db

ALERT_THRESHOLD=5
RATE_LIMIT_THRESHOLD=10
BLOCK_THRESHOLD=15
TIME_WINDOW_MINUTES=10
UNBLOCK_AFTER_HOURS=24
ADMIN_IP=127.0.0.1

# Optional email alerts (leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=ssh-detector@localhost
SMTP_TO=

CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost
